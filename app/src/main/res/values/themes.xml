<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NammaYantraShare" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorError">@color/error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.NammaYantraShare.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
        <item name="android:colorBackground">@color/splash_bg</item>
    </style>

    <style name="Theme.NammaYantraShare.Auth" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <!-- Custom button styles -->
    <style name="Widget.NammaYantra.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.NammaYantra.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.NammaYantra.Button.Accept" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/status_accepted_bg</item>
        <item name="android:textColor">@color/status_accepted</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>

    <style name="Widget.NammaYantra.Button.Decline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/status_declined</item>
        <item name="android:textColor">@color/status_declined</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Text input styles -->
    <style name="Widget.NammaYantra.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="boxBackgroundColor">@color/white</item>
    </style>

    <!-- Card styles -->
    <style name="Widget.NammaYantra.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
    </style>

    <style name="Widget.NammaYantra.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">20dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
    </style>

    <!-- Proper dialog theme - inherits from Material3 dialog, NOT the full-screen app theme -->
    <style name="Theme.NammaYantra.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:background">@color/white</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.NammaYantra.Button.DialogPositive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.NammaYantra.Button.DialogNegative</item>
    </style>

    <style name="Widget.NammaYantra.Button.DialogPositive" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>

    <style name="Widget.NammaYantra.Button.DialogNegative" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>
